# =============================================================
# GotongLedger Web - Environment Variables
# =============================================================

# Chain Environment: "localhost" or "sepolia"
NEXT_PUBLIC_CHAIN_ENV="localhost"

# RPC Configuration
NEXT_PUBLIC_RPC_URL="http://127.0.0.1:8545"

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="your-project-id"

# IPFS Configuration (matches docker-compose ports)
IPFS_API_URL="http://127.0.0.1:5881"
NEXT_PUBLIC_IPFS_GATEWAY_URL="http://127.0.0.1:8882"

# Database (PostgreSQL via Docker Compose, matches docker-compose ports)
DATABASE_URL="postgresql://gotong:gotong123@localhost:5883/gotongledger"

# For production with Pinata:
# NEXT_PUBLIC_IPFS_GATEWAY_URL="https://gateway.pinata.cloud"
# PINATA_API_KEY="your-api-key"
# PINATA_SECRET_KEY="your-secret-key"

# Sepolia Deployment (contracts/.env)
# SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY"
# DEPLOYER_PRIVATE_KEY="your-private-key"
